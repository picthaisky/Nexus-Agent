# ============================================================
# Nexus-Agent — Stack Environment Variables
# ============================================================
# Copy this file and fill in your actual values:
#   cp Stack.env .env.local
#
# For Portainer: Upload this file when creating/editing the Stack
# For local dev: docker compose --env-file Stack.env up -d
# ============================================================

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=production
APP_VERSION=0.1.0
NEXUS_IMAGE_TAG=latest
# Host ports — เลือกให้ไม่ชนกับ container อื่นบน Portainer host
NEXUS_PORT=5190        # FastAPI backend (container :8080)
DASHBOARD_PORT=3990    # React/nginx UI    (container :80)
LOG_LEVEL=INFO
WEB_CONCURRENCY=2

# ── CORS ─────────────────────────────────────────────────────
# Production: comma-separated allow-list; wildcard is rejected at startup.
# Example: CORS_ORIGINS=https://nexus.example.com,https://admin.example.com
CORS_ORIGINS=*

# ── Security / Auth ──────────────────────────────────────────
# Comma-separated API keys.  Generate with:  openssl rand -hex 32
NEXUS_AUTH_REQUIRED=true
NEXUS_API_KEYS=
NEXUS_ADMIN_API_KEYS=
# Token clients must pass as ?token=... when connecting to /ws/dashboard.
NEXUS_WS_TOKEN=

# ── Rate limiting (slowapi syntax: "<n>/<period>") ───────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_INFERENCE=20/minute

# ── Observability ────────────────────────────────────────────
JSON_LOGS=true
METRICS_ENABLED=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Reliability ──────────────────────────────────────────────
INFERENCE_TIMEOUT_SECONDS=60
INFERENCE_MAX_RETRIES=3
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_SECONDS=60

# ── DB pool ──────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── OpenAI / LLM (Cloud Inference) ──────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic Claude ────────────────────────────────────────
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# ── Google Gemini ───────────────────────────────────────────
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Azure OpenAI / Custom OpenAI-Compatible Endpoint ────────
# Override OPENAI_BASE_URL above with your Azure/LM-Studio/Ollama URL.
# e.g. OPENAI_BASE_URL=http://localhost:11434/v1   (Ollama)
#      OPENAI_BASE_URL=http://localhost:1234/v1    (LM Studio)

# ── vLLM (Local Inference — optional) ───────────────────────
# เปิดใช้งานเมื่อต้องการ run local inference แทน cloud
VLLM_ENABLED=false
VLLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=4096

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=nexus_redis_secret
REDIS_PORT=6399          # host:6399 → container:6379 (เลี่ยง redis อื่นบน host)
REDIS_MAX_MEMORY=256mb
# NOTE: REDIS_URL is constructed by docker-compose.yml dynamically
# Override here only for standalone (non-compose) deployment:
# REDIS_URL=redis://:nexus_redis_secret@localhost:6379/0

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
POSTGRES_DB=nexus_agent
POSTGRES_PORT=5492        # host:5492 → container:5432 (เลี่ยง postgres อื่นบน host)
# NOTE: DATABASE_URL is constructed by docker-compose.yml dynamically
# Override here only for standalone (non-compose) deployment:
# DATABASE_URL=postgresql://nexus:nexus_secret@localhost:5432/nexus_agent

# ── Portainer Deployment ─────────────────────────────────────
# Webhook URL จาก Portainer Stack (ตั้งค่าใน Portainer)
# ใช้เป็น GitHub Secret: PORTAINER_WEBHOOK_URL
# PORTAINER_WEBHOOK_URL=https://your-portainer.example.com/api/stacks/webhooks/xxxxxx
